# OpenAI-compatible LLM configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# OpenAI embeddings used for the Pinecone retrieval backend.
# OPENAI_EMBEDDING_DIMENSION must match the configured Pinecone index dimension.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# Pinecone retrieval backend configuration
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
